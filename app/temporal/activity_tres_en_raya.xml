<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".games.tresenraya.TresEnRaya">

    <TextView
        android:id="@+id/textViewTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="44dp"
        android:gravity="center"
        android:text="Tres en Raya"
        android:textSize="24sp"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="Tu turno (X)"
        android:textSize="34sp"
        app:layout_constraintTop_toBottomOf="@+id/textViewTitle" />

    <GridLayout
        android:id="@+id/gridLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:columnCount="3"
        android:rowCount="3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvStatus">

        <!-- Se eliminó el estilo Borderless para que el background funcione correctamente -->
        <Button android:id="@+id/btn_0" android:layout_width="100dp" android:layout_height="100dp" android:layout_margin="4dp" android:background="@drawable/bordeazul" android:textColor="#000000" android:textSize="32sp" app:backgroundTint="@null" />
        <Button android:id="@+id/btn_1" android:layout_width="100dp" android:layout_height="100dp" android:layout_margin="4dp" android:background="@drawable/bordeamarillo" android:textColor="#000000" android:textSize="32sp" app:backgroundTint="@null" />
        <Button android:id="@+id/btn_2" android:layout_width="100dp" android:layout_height="100dp" android:layout_margin="4dp" android:background="@drawable/borderosa" android:textColor="#000000" android:textSize="32sp" app:backgroundTint="@null" />

        <Button android:id="@+id/btn_3" android:layout_width="100dp" android:layout_height="100dp" android:layout_margin="4dp" android:background="@drawable/borderosa" android:textColor="#000000" android:textSize="32sp" app:backgroundTint="@null" />
        <Button android:id="@+id/btn_4" android:layout_width="100dp" android:layout_height="100dp" android:layout_margin="4dp" android:background="@drawable/bordeazul" android:textColor="#000000" android:textSize="32sp" app:backgroundTint="@null" />
        <Button android:id="@+id/btn_5" android:layout_width="100dp" android:layout_height="100dp" android:layout_margin="4dp" android:background="@drawable/bordeamarillo" android:textColor="#000000" android:textSize="32sp" app:backgroundTint="@null" />

        <Button android:id="@+id/btn_6" android:layout_width="100dp" android:layout_height="100dp" android:layout_margin="4dp" android:background="@drawable/bordeamarillo" android:textColor="#000000" android:textSize="32sp" app:backgroundTint="@null" />
        <Button android:id="@+id/btn_7" android:layout_width="100dp" android:layout_height="100dp" android:layout_margin="4dp" android:background="@drawable/borderosa" android:textColor="#000000" android:textSize="32sp" app:backgroundTint="@null" />
        <Button android:id="@+id/btn_8" android:layout_width="100dp" android:layout_height="100dp" android:layout_margin="4dp" android:background="@drawable/bordeazul" android:textColor="#000000" android:textSize="32sp" app:backgroundTint="@null" />
    </GridLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panelVictoria"
        android:layout_width="391dp"
        android:layout_height="735dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/shadow_bottom2"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewTitle">

        <TextView
            android:id="@+id/textView16"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="40dp"
            android:layout_marginTop="64dp"
            android:text="¡Enhorabuena!"
            android:textSize="48sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/imageView3"
            android:layout_width="102dp"
            android:layout_height="176dp"
            android:layout_marginTop="104dp"
            android:layout_marginEnd="40dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/decoracion" />

        <ImageView
            android:id="@+id/imageView8"
            android:layout_width="101dp"
            android:layout_height="178dp"
            android:layout_marginStart="40dp"
            android:layout_marginTop="104dp"
            android:scaleX="-1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/decoracion" />

        <ImageView
            android:id="@+id/imageView7"
            android:layout_width="212dp"
            android:layout_height="179dp"
            android:layout_marginStart="88dp"
            android:layout_marginTop="48dp"
            android:src="@drawable/palmas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView16" />

        <TextView
            android:id="@+id/textView17"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="128dp"
            android:layout_marginTop="48dp"
            android:text="+100 pts"
            android:textSize="34sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imageView7" />

        <Button
            android:id="@+id/button"
            android:layout_width="235dp"
            android:layout_height="53dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginStart="76dp"
            android:layout_marginTop="56dp"
            android:backgroundTint="#000000"
            android:text="VOLVER AL MENU"
            android:textAllCaps="true"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="30dp"
            app:elevation="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView17" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panelEmpate"
        android:layout_width="391dp"
        android:layout_height="735dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/shadow_bottom2"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewTitle">

        <TextView
            android:id="@+id/textView20"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="100dp"
            android:layout_marginTop="64dp"
            android:text="¡Empate!"
            android:textSize="48sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/imageView77"
            android:layout_width="212dp"
            android:layout_height="179dp"
            android:layout_marginStart="88dp"
            android:layout_marginTop="48dp"
            android:src="@drawable/guantes"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView20" />

        <TextView
            android:id="@+id/textView177"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="136dp"
            android:layout_marginTop="48dp"
            android:text="+30 pts"
            android:textSize="34sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imageView77" />

        <Button
            android:id="@+id/button2"
            android:layout_width="235dp"
            android:layout_height="53dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginStart="76dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#000000"
            android:text="VOLVER AL MENU"
            android:textAllCaps="true"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="30dp"
            app:elevation="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView177" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panelDerrota"
        android:layout_width="391dp"
        android:layout_height="735dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/shadow_bottom2"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewTitle">

        <TextView
            android:id="@+id/textView200"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="88dp"
            android:layout_marginTop="68dp"
            android:text="Perdiste..."
            android:textSize="48sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/imageView777"
            android:layout_width="212dp"
            android:layout_height="179dp"
            android:layout_marginStart="88dp"
            android:layout_marginTop="48dp"
            android:src="@drawable/_0a2461a_296c_4ea5_a16f_8271f3b7da9b"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView200" />

        <TextView
            android:id="@+id/textView1777"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="148dp"
            android:layout_marginTop="48dp"
            android:text="+0 pts"
            android:textSize="34sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imageView777" />

        <Button
            android:id="@+id/button22"
            android:layout_width="235dp"
            android:layout_height="53dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginStart="76dp"
            android:layout_marginTop="56dp"
            android:backgroundTint="#000000"
            android:text="VOLVER AL MENU"
            android:textAllCaps="true"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="30dp"
            app:elevation="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView1777" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>